# Database
DATABASE_URL=postgresql://audit_user:audit_pass@localhost:5432/audit_api

# Redis
REDIS_URL=redis://localhost:6379

# RAG Engine
RAG_ENGINE_URL=http://localhost:8001

# JWT Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# ── Provider abstraction ──────────────────────────────────────────────────────
# Single key for OpenRouter (covers all tiers via one gateway).
# Leave blank if you set per-tier keys or use OPENAI_API_KEY directly.
OPENROUTER_API_KEY=
# Legacy OpenAI key — only needed if NOT using OpenRouter
OPENAI_API_KEY=

# ── 🟢 Small tier — Qwen3-8B (classifier, routing) ──────────────────────────
SMALL_MODEL_PROVIDER=openai_compatible
SMALL_MODEL_NAME=qwen/qwen3-8b
SMALL_MODEL_BASE_URL=https://openrouter.ai/api/v1
# SMALL_MODEL_API_KEY=   # optional: defaults to OPENROUTER_API_KEY

# ── 🟡 Mid tier — DeepSeek-V3 (planner, critic) ──────────────────────────────
MID_MODEL_PROVIDER=openai_compatible
MID_MODEL_NAME=deepseek/deepseek-chat-v3-0324
MID_MODEL_BASE_URL=https://openrouter.ai/api/v1
# MID_MODEL_API_KEY=

# ── 🔴 Frontier tier — Claude Sonnet 4.5 (synthesis, final answers) ──────────
FRONTIER_MODEL_PROVIDER=openai_compatible
FRONTIER_MODEL_NAME=anthropic/claude-sonnet-4-5
FRONTIER_MODEL_BASE_URL=https://openrouter.ai/api/v1
# FRONTIER_MODEL_API_KEY=

# Server
PORT=8000
NODE_ENV=development

# ─── Phase 3: SSO / OIDC ────────────────────────────────────────────
OIDC_ENABLED=false
OIDC_ISSUER=https://your-idp.example.com
OIDC_CLIENT_ID=audit-assistant
OIDC_CLIENT_SECRET=your-client-secret
OIDC_CALLBACK_URL=http://localhost:8000/auth/oidc/callback
OIDC_SCOPE=openid profile email
OIDC_ROLES_CLAIM=roles
OIDC_GROUPS_CLAIM=groups

# ─── Phase 3: SSO / SAML ────────────────────────────────────────────
SAML_ENABLED=false
SAML_ENTRY_POINT=https://your-idp.example.com/saml/sso
SAML_ISSUER=audit-assistant
SAML_CERT=
SAML_CALLBACK_URL=http://localhost:8000/auth/saml/callback
SAML_ROLE_ATTRIBUTE=Role
SAML_GROUP_ATTRIBUTE=Group

# ─── Phase 3: Rate Limiting ─────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=60
THROTTLE_LOGIN_TTL=60
THROTTLE_LOGIN_LIMIT=5

# ─── Phase 3: Secrets Management ────────────────────────────────────
SECRETS_ENCRYPTION_KEY=change-me-32-chars-min-in-prod!!
SECRETS_ROTATION_INTERVAL_DAYS=90
